# ── Database ───────────────────────────────────────────────────────────────
# MongoDB Atlas connection string (M0 free tier is fine for ~100 tenants).
MONGODB_URI="mongodb+srv://USER:PASSWORD@cluster0.xxxx.mongodb.net/coaching_center"

# ── Auth.js / NextAuth v5 ───────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
AUTH_SECRET="replace-with-a-long-random-string"
# Public base URL. In local dev keep it as below; in prod use https://yourdomain.com
NEXTAUTH_URL="http://localhost:3000"

# ── Multi-tenant routing ────────────────────────────────────────────────────
# Root domain WITHOUT protocol. Tenants live at /{slug}/admin on this domain.
# Local dev: "localhost:3000"  -> http://localhost:3000/zilani/admin
# Production: "sass-coaching-management.vercel.app" -> https://.../zilani/admin
# Later with custom domain + wildcard DNS you can switch back to subdomains.
ROOT_DOMAIN="localhost:3000"

# ── Super admin seed (used by `npm run seed:superadmin`) ─────────────────────
SUPERADMIN_PHONE="01568109275"
SUPERADMIN_PASSWORD="01568109275"
SUPERADMIN_NAME="Super Admin"

# ── SMS gateway (optional; default is a no-op stub that only logs) ───────────
# SMS_PROVIDER=stub | bulksmsbd | ...
SMS_PROVIDER="stub"
SMS_API_URL=""
SMS_API_KEY=""
SMS_SENDER_ID=""
